<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- The companion talks to the Cyclops brain server over the LAN (HTTP). -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- COLMI R02 ring: BLE central (scan + connect). -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.Cyclops">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="stateHidden|adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".RingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".HudMirrorActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".RemapActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".TranscriptActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <!-- BLE hub: pumps wearable frames into HudBridge, forwards
             display frames back to the device. Started by the app
             with EXTRA_MAC once BLUETOOTH_CONNECT is granted. -->
        <service
            android:name=".CyclopsService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice" />

        <activity
            android:name=".MemoryActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait" />

        <receiver
            android:name=".HudWidgetProvider"
            android:exported="false">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/hud_widget_info" />
        </receiver>
    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/cyclops_surface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Welcome to Cyclops"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/cyclops_primary" />

    <!-- page 0: the two buttons -->
    <LinearLayout
        android:id="@+id/page0"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Two buttons. That's it."
            android:textSize="16sp"
            android:textColor="@color/cyclops_on_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="A · EYE  — look / photo / video"
            android:textSize="15sp"
            android:textColor="@color/cyclops_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="B · EAR  — back / voice note / voice cmd"
            android:textSize="15sp"
            android:textColor="@color/cyclops_secondary" />
    </LinearLayout>

    <!-- page 1: gestures -->
    <LinearLayout
        android:id="@+id/page1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Each button, three ways"
            android:textSize="16sp"
            android:textColor="@color/cyclops_on_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="single tap · double tap · long press"
            android:textSize="15sp"
            android:textColor="@color/cyclops_secondary" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Remap any of the 6 slots from the app."
            android:textSize="15sp"
            android:textColor="@color/cyclops_secondary" />
    </LinearLayout>

    <!-- page 2: live + done -->
    <LinearLayout
        android:id="@+id/page2"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mirror &amp; memory"
            android:textSize="16sp"
            android:textColor="@color/cyclops_on_surface" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="See the live HUD, browse memories, drop the widget on your home screen."
            android:textSize="15sp"
            android:textColor="@color/cyclops_secondary" />
    </LinearLayout>

    <Button
        style="@style/Widget.Cyclops.Button.Primary"
        android:id="@+id/btnOnboardNext"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Next" />

    <TextView
        android:id="@+id/btnOnboardSkip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:padding="12dp"
        android:text="Skip"
        android:textColor="@color/cyclops_secondary"
        android:contentDescription="Skip the intro" />

</LinearLayout>

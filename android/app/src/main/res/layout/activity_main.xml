<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar carries the hamburger + title + connection status pill. -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/cyclops_surface"
        app:title="@string/app_name"
        app:titleTextColor="@color/cyclops_primary">

        <TextView
            android:id="@+id/txtStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:padding="8dp"
            android:text="●"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/cyclops_secondary"
            android:contentDescription="Brain connection status — tap for settings" />
    </com.google.android.material.appbar.MaterialToolbar>

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listNotes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/txtEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/empty"
        android:visibility="gone"
        android:gravity="center"
        android:textColor="@color/cyclops_secondary" />

    <!-- Dev tools (raw ingest/extract) are not the product surface: they made
         the home screen read like a debug panel. Collapsed by default. -->
    <TextView
        android:id="@+id/btnDevToggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="6dp"
        android:text="▸ Dev tools"
        android:textSize="12sp"
        android:textColor="@color/cyclops_secondary"
        android:contentDescription="Show or hide raw ingest and extract fields" />

    <LinearLayout
        android:id="@+id/devPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/editIngest"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ingest_hint"
        android:inputType="textMultiLine"
        android:minLines="2" />

    <Button
        android:id="@+id/btnIngest"
        android:contentDescription="Ingest text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/ingest" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/editExtract"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/extract_hint" />

    <Button
        android:id="@+id/btnExtract"
        android:contentDescription="Extract facts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/extract" />
    </LinearLayout>

    <!-- Primary interaction: ask the brain. Kept above the ask bar so the
         answer + HUD banner sit directly over where you type. -->
    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/editAsk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/ask_hint" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Local model"
            android:textColor="@color/cyclops_secondary" />
        <Switch
            android:id="@+id/swLocal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />
        <!-- Transport is resolved automatically (cable > BLE > wifi); the
             manual override lives in Settings for debugging. -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="link: auto"
            android:textSize="12sp"
            android:textColor="@color/cyclops_secondary" />
    </LinearLayout>

    <Button
        style="@style/Widget.Cyclops.Button.Primary"
        android:id="@+id/btnAsk"
        android:contentDescription="Ask the brain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/send" />

    <!-- Glanceable HUD mirror: shows the banner the wearable glasses would display -->
    <TextView
        android:id="@+id/txtHud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:padding="12dp"
        android:background="@drawable/bg_hud_banner"
        android:textColor="@color/cyclops_accent"
        android:textStyle="bold"
        android:textSize="13sp"
        android:text="@string/hud_idle" />

    <TextView
        android:id="@+id/txtChat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:padding="12dp"
        android:background="@drawable/bg_panel"
        android:textColor="@color/cyclops_on_surface"
        android:textIsSelectable="true"
        android:visibility="gone" />

  </LinearLayout>
  </LinearLayout>

  <com.google.android.material.navigation.NavigationView
      android:id="@+id/navView"
      android:layout_width="wrap_content"
      android:layout_height="match_parent"
      android:layout_gravity="start"
      android:background="@color/cyclops_surface"
      app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>

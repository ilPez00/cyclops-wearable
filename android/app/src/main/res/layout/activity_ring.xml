<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ring_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#00E5FF" />

        <Button
            style="@style/Widget.Cyclops.Button.Primary"
        android:id="@+id/btnRingConnect"
        android:contentDescription="Connect COLMI ring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/ring_connect" />

        <TextView
            android:id="@+id/txtRingStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/cyclops_secondary"
            android:text="@string/ring_idle" />

        <!-- Live radial gauges (HR + SpO2) and battery bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <com.cyclops.companion.RadialGaugeView
                android:id="@+id/gaugeHr"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_weight="1"
                android:contentDescription="Heart rate gauge" />

            <com.cyclops.companion.RadialGaugeView
                android:id="@+id/gaugeSpo2"
                android:layout_width="0dp"
                android:layout_height="180dp"
                android:layout_weight="1"
                android:contentDescription="Blood oxygen gauge" />
        </LinearLayout>

        <com.cyclops.companion.BatteryBarView
            android:id="@+id/barBatt"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="12dp"
            android:contentDescription="Ring battery level" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="12sp"
            android:textColor="@color/cyclops_secondary"
            android:text="@string/ring_note" />
    </LinearLayout>
</FrameLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Button remap"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#00E5FF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/cyclops_secondary"
        android:text="A = eye (ok/photo/video) · B = ear (back/voice-note/voice-cmd). Tap a cell to rebind." />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <TableLayout
            android:id="@+id/tblRemap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:stretchColumns="0,1,2,3" />
    </HorizontalScrollView>

    <Button
        android:id="@+id/btnRemapReset"
        android:contentDescription="Reset remap to defaults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Reset to defaults" />

    <Button
        android:id="@+id/btnRemapSave"
        android:contentDescription="Save remap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save &amp; push to device" />
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Haptic &amp; LED per button"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/cyclops_primary" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="0,1,2"
        android:layout_marginTop="4dp">
        <TableRow>
            <TextView android:text="" android:padding="8dp" />
            <TextView android:text="Haptic" android:padding="8dp" android:textColor="@color/cyclops_secondary" />
            <TextView android:text="LED hue" android:padding="8dp" android:textColor="@color/cyclops_secondary" />
        </TableRow>
        <TableRow>
            <TextView android:text="A (eye)" android:padding="8dp" android:textColor="@color/cyclops_on_surface" />
            <Spinner android:id="@+id/spinHapticA" android:padding="8dp" android:contentDescription="Haptic pattern for button A" />
            <Spinner android:id="@+id/spinLedA" android:padding="8dp" android:contentDescription="LED hue for button A" />
        </TableRow>
        <TableRow>
            <TextView android:text="B (ear)" android:padding="8dp" android:textColor="@color/cyclops_on_surface" />
            <Spinner android:id="@+id/spinHapticB" android:padding="8dp" android:contentDescription="Haptic pattern for button B" />
            <Spinner android:id="@+id/spinLedB" android:padding="8dp" android:contentDescription="LED hue for button B" />
        </TableRow>
    </TableLayout>

    <Button
        android:id="@+id/btnRemapSaveHaptic"
        android:contentDescription="Save haptic and LED mapping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Save haptic &amp; LED" />


    <TextView
        android:id="@+id/txtRemapStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/cyclops_secondary" />
</LinearLayout>

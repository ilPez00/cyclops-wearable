<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Button remap"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#00E5FF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="#888"
        android:text="A = eye (ok/photo/video) · B = ear (back/voice-note/voice-cmd). Tap a cell to rebind." />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp">

        <TableLayout
            android:id="@+id/tblRemap"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:stretchColumns="0,1,2,3" />
    </HorizontalScrollView>

    <Button
        android:id="@+id/btnRemapReset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Reset to defaults" />

    <Button
        android:id="@+id/btnRemapSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save &amp; push to device" />

    <TextView
        android:id="@+id/txtRemapStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#888" />
</LinearLayout>

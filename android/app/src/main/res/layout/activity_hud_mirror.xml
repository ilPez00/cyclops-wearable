<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="A preview of what the wearable's OLED shows. Demo plays sample frames; Live mirrors your connected device."
        android:textSize="13sp"
        android:textColor="@color/cyclops_secondary" />

    <TextView
        android:id="@+id/txtHudStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textSize="12sp"
        android:textColor="@color/cyclops_secondary"
        android:background="@color/cyclops_surface_variant"
        android:padding="6dp"
        android:contentDescription="HUD connection status" />

    <com.cyclops.companion.HudMirrorView
        android:id="@+id/hudMirror"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="@color/cyclops_surface"
        android:contentDescription="Live mirror of the wearable OLED HUD" />

    <Button
        style="@style/Widget.Cyclops.Button.Primary"
        android:id="@+id/btnHudDemo"
        android:contentDescription="Switch between demo and live mirror"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Switch to Live" />
</LinearLayout>

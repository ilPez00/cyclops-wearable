<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Wearable HUD mirror"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/cyclops_primary" />

    <TextView
        android:id="@+id/txtHudStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="#8A9BA8"
        android:background="@color/cyclops_surface_variant"
        android:padding="4dp"
        android:contentDescription="HUD connection status" />

    <com.cyclops.companion.HudMirrorView
        android:id="@+id/hudMirror"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="12dp"
        android:background="@color/cyclops_surface"
        android:contentDescription="Live mirror of the wearable OLED HUD" />

    <Button
        android:id="@+id/btnHudDemo"
        android:contentDescription="Toggle live / demo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Live" />
</LinearLayout>
